# ==========================================
# 1. DEPENDENCIAS Y COMPILACIÓN (MAVEN)
# ==========================================
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
# Ignoramos el JAR del wrapper, pero dejamos los scripts (mvnw, mvnw.cmd)
.mvn/wrapper/maven-wrapper.jar

# ==========================================
# 2. SEGURIDAD Y SECRETOS (¡CRÍTICO!)
# ==========================================
# Previene la subida accidental de llaves de API, contraseñas de BD y tokens
.env
*.env
.env.*
application-local.properties
application-secret.properties
application-dev.yml
secrets/
*.pem
*.key
*.p12
*.jks

# ==========================================
# 3. LOGS, CACHÉ Y TEMPORALES
# ==========================================
# Evita subir gigabytes de texto inútil al repositorio
*.log
logs/
*.gz
/tmp/
hs_err_pid*

# ==========================================
# 4. BASURA DEL SISTEMA OPERATIVO
# ==========================================
# Evita conflictos entre desarrolladores que usan Mac y Windows
.DS_Store
.DS_Store?
._*
.Trashes
ehthumbs.db
Thumbs.db

